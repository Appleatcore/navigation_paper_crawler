{
  "notion_token": "YOUR_NOTION_TOKEN_HERE",
  "database_id": "YOUR_DATABASE_ID_HERE",

  "chemistry_domain": "plastic degradation",
  "target_websites": [
    "x-mol",
    "web_of_science",
    "scifinder"
  ],
  "source_preferences": [
    "x_mol",
    "openalex",
    "crossref"
  ],
  "keywords": [
    "ionic liquid",
    "plastic degradation",
    "high-value recycling",
    "W catalysis",
    "tungsten catalysis",
    "PET degradation",
    "polycarbonate degradation",
    "PLA degradation",
    "polyethylene terephthalate",
    "polycarbonate",
    "polylactic acid"
  ],
  "exclude_keywords": [
    "navigation",
    "robot",
    "autonomous driving"
  ],
  "days_back": 4,
  "max_papers": 3,
  "xmol_max_results": 10,
  "openalex_max_results": 10,
  "crossref_max_results": 10,
  "semantic_scholar_max_results": 0,
  "use_semantic_scholar": false,
  "enrich_citations": false,
  "enrich_impact": false,
  "enrich_institutions": true,
  "extract_figures": false,
  "recommend_score_enabled": true,
  "llm_recommend_score_enabled": true,
  "llm_provider": "openai-compatible",
  "llm_model": "qwen-vl-plus",
  "llm_api_base": "https://dashscope.aliyuncs.com/compatible-mode/v1",
  "llm_api_key": "YOUR_LLM_API_KEY_HERE",
  "llm_max_papers": 50,
  "llm_call_interval_s": 1.0,
  "llm_temperature": 0.2,
  "llm_timeout": 120,
  "llm_max_tokens": 500,
  "llm_use_full_pdf": false,
  "llm_pdf_max_pages": 20,
  "llm_pdf_max_chars": 30000,
  "llm_pdf_extract_images": false,
  "llm_pdf_max_images": 0,
  "log_level": "INFO",

  "patch_config": {
    "enabled": false,
    "max_papers_to_scan": 10,
    "fields_to_patch": ["pdf_url", "institutions", "citations", "recommend_score"],

    "pdf_url": {
      "enabled": true,
      "max_papers": 50
    },

    "citations": {
      "enabled": false,
      "max_papers": 30
    },

    "institutions": {
      "enabled": true,
      "max_papers": 30
    },

    "recommend_score": {
      "enabled": false,
      "max_papers": 20,
      "use_full_pdf": true
    }
  }
}
